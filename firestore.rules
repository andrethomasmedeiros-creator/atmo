rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Casos PTM - acesso público controlado pela senha do app (SHA-256)
    match /casos/{casoId} {
      allow read, write: if true;
    }

    // Configurações do sistema (incluindo hashes de senha)
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Chat geral
    match /chat_geral/{msgId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Logs de auditoria - imutáveis após criação
    match /logs/{logId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
  }
}
