rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Casos PTM - apenas usuários autenticados
    match /casos/{casoId} {
      allow read, write: if request.auth != null;
    }

    // Configurações do sistema (incluindo hashes de senha)
    // Leitura pública para permitir verificação de senha no login
    // Escrita restrita a autenticados
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Chat geral (mensagens sem caso ativo)
    match /chat_geral/{msgId} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // Logs de auditoria - imutáveis após criação
    match /logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
