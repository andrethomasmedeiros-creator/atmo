rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para casos PTM
    match /casos/{casoId} {
      // Permitir leitura para todos (telas do hospital)
      allow read: if true;
      
      // Permitir escrita para todos (em produção, adicionar autenticação)
      allow write: if true;
    }
    
    // Regras para configurações
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Regras para logs/auditoria
    match /logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false; // Logs não podem ser alterados
    }
  }
}
